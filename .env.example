# 1. اعمل Notion Integration من: https://www.notion.so/my-integrations
# 2. انسخ الـ token هنا
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 3. افتح الـ Database في Notion، انسخ الـ URL
#    مثال: https://www.notion.so/workspace/abc123def456...  -> الـ ID هو الجزء ده
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
